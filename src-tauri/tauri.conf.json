{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "taunter",
  "version": "0.3.0",
  "identifier": "com.tsoft.taunter",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "taunter",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCRDUwQzlENUMwMzc2RTEKUldUaGRnTmNuUXpWZTNMdWQzekg5NHNsWkc4dE0yWHlzUjdPNjc5MXFoOVhtMjNvWjhsblNuWEYK",
      "endpoints": [
        "https://github.com/Tomate-soft/taunter/releases/latest/download/latest.json"
      ]
    }
  }
}
